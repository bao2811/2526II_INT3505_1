#%RAML 0.8
title: Library Management API
version: v1
baseUri: http://localhost:8080/api
mediaType: application/json

# 1. Định nghĩa kiểu dữ liệu (Schema)
schemas:
  - Book: |
      {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "Book",
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "title": {"type": "string"},
          "author": {"type": "string"},
          "isbn": {"type": "string"}
        },
        "required": ["title", "author"]
      }
  - BookList: |
      {
        "$schema": "http://json-schema.org/draft-04/schema#",
        "title": "BookList",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {"type": "integer"},
            "title": {"type": "string"},
            "author": {"type": "string"},
            "isbn": {"type": "string"}
          },
          "required": ["title", "author"]
        }
      }

# 2. Định nghĩa các Tài nguyên (Routes)
/books:
  get:
    description: Lấy danh sách toàn bộ sách trong thư viện.
    responses:
      200:
        body:
          application/json:
            schema: BookList
            example: |
              [
                {"id": 1, "title": "So Do", "author": "Vu Trong Phung"},
                {"id": 2, "title": "Lao Hac", "author": "Nam Cao"}
              ]

  post:
    description: Thêm một cuốn sách mới vào hệ thống.
    body:
      application/json:
        schema: |
          {
            "$schema": "http://json-schema.org/draft-04/schema#",
            "title": "Book",
            "type": "object",
            "properties": {
              "id": {"type": "integer"},
              "title": {"type": "string"},
              "author": {"type": "string"},
              "isbn": {"type": "string"}
            },
            "required": ["title", "author"]
          }
    responses:
      201:
        body:
          application/json:
            schema: |
              {
                "$schema": "http://json-schema.org/draft-04/schema#",
                "title": "Book",
                "type": "object",
                "properties": {
                  "id": {"type": "integer"},
                  "title": {"type": "string"},
                  "author": {"type": "string"},
                  "isbn": {"type": "string"}
                },
                "required": ["title", "author"]
              }
            example: |
              {"id": 3, "title": "Tat Den", "author": "Ngo Tat To"}

  /{id}:
    uriParameters:
      id:
        type: integer
    
    get:
      description: Lấy thông tin chi tiết một cuốn sách theo ID.
      responses:
        200:
          body:
            application/json:
              schema: |
                {
                  "$schema": "http://json-schema.org/draft-04/schema#",
                  "title": "Book",
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "title": {"type": "string"},
                    "author": {"type": "string"},
                    "isbn": {"type": "string"}
                  },
                  "required": ["title", "author"]
                }
        404:
          body:
            application/json:
              example: |
                {"message": "Khong tim thay sach"}

    put:
      description: Cập nhật thông tin cuốn sách hiện có.
      body:
        application/json:
          schema: |
            {
              "$schema": "http://json-schema.org/draft-04/schema#",
              "title": "Book",
              "type": "object",
              "properties": {
                "id": {"type": "integer"},
                "title": {"type": "string"},
                "author": {"type": "string"},
                "isbn": {"type": "string"}
              },
              "required": ["title", "author"]
            }
      responses:
        200:
          body:
            application/json:
              schema: |
                {
                  "$schema": "http://json-schema.org/draft-04/schema#",
                  "title": "Book",
                  "type": "object",
                  "properties": {
                    "id": {"type": "integer"},
                    "title": {"type": "string"},
                    "author": {"type": "string"},
                    "isbn": {"type": "string"}
                  },
                  "required": ["title", "author"]
                }

    delete:
      description: Xóa cuốn sách khỏi hệ thống.
      responses:
        204:
          description: Xóa thành công, không có nội dung trả về.
        404:
          body:
            application/json:
              example: |
                {"message": "Sach khong ton tai de xoa"}