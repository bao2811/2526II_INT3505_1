{
  "info": {
    "_postman_id": "2a942030-715f-4f6f-9944-caecfe91a69f",
    "name": "Week 8 - Product API Testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. GET /products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["products"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time < 500ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Response has data array\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property(\"data\");",
              "  pm.expect(body.data).to.be.an(\"array\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. POST /products",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Product\",\n  \"description\": \"Created by Postman\",\n  \"price\": 15.5,\n  \"inStock\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["products"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response time < 500ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Created product has id\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property(\"id\");",
              "  pm.environment.set(\"productId\", body.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. GET /products/{id}",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["products", "{{productId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time < 500ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Response id matches environment\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.id).to.eql(pm.environment.get(\"productId\"));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. PUT /products/{id}",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Product Updated\",\n  \"description\": \"Updated by Postman\",\n  \"price\": 20,\n  \"inStock\": false\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/products/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["products", "{{productId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time < 500ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Product is updated\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.name).to.eql(\"Postman Product Updated\");",
              "  pm.expect(body.inStock).to.eql(false);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. DELETE /products/{id}",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["products", "{{productId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time < 500ms\", function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});",
              "",
              "pm.test(\"Delete response has deleted object\", function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property(\"deleted\");",
              "  pm.expect(body.deleted.id).to.eql(pm.environment.get(\"productId\"));",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
